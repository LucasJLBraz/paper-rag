# Written by `paper-rag init` (or copy by hand to <repo root>/.paper-rag.toml).
# All paths are relative to the directory this file lives in.

[corpus]
papers_dir = "references/Papers"

[index]
dir = ".rag_index"
table_name = "chunks"

[embedding]
# "sentence-transformers" (default, no external server) or "ollama"
# multilingual-e5-small: fast on CPU (no CUDA needed), multilingual, good
# fit for STEM papers with mixed-language queries. See HANDOFF.md for the
# bge-m3 speed/quality comparison that led to this default.
backend = "sentence-transformers"
model = "intfloat/multilingual-e5-small"
ollama_host = "http://localhost:11434"

[chunking]
max_tokens = 400
overlap_tokens = 60

[ingest]
# A single malformed PDF can otherwise hang an entire `build` run — see
# HANDOFF.md. Lower this if you want faster failure on bad PDFs, raise it
# for very large legitimate papers on a slow machine.
pdf_timeout_seconds = 120

[acquire]
# Required by Unpaywall's "polite pool" and requested by OpenAlex/Semantic Scholar.
contact_email = "you@example.com"
# Optional — raises Semantic Scholar's rate limit if set.
semantic_scholar_api_key = ""
